{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd 'Web Development/hashan sudees/backend' && npm install",
    "watchPatterns": ["Web Development/hashan sudees/backend/**"]
  },
  "deploy": {
    "startCommand": "cd 'Web Development/hashan sudees/backend' && node server.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "on-failure"
  }
}
